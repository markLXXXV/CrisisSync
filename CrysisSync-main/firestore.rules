rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Master Security Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    
    // 2. Global Deny-All (Safety Net)
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId
          && data.email is string
          && (!('name' in data) || (data.name is string && data.name.size() <= 100))
          && (!('status' in data) || (data.status in ['ACTIVE', 'OFFLINE', 'SOS_ACTIVE']))
          && (!('phone' in data) || (data.phone is string && data.phone.size() <= 20))
          && (!('address' in data) || (data.address is string && data.address.size() <= 500));
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'photoURL', 'status', 'phone', 'alternatePhone', 
          'address', 'pronouns', 'updatedAt', 'verified'
        ])
      );
      
      // AI Help Chat History (Private)
      match /chatHistory/{messageId} {
        function isValidMessage(data) {
          return data.userId == userId
            && data.role in ['user', 'ai']
            && data.content is string;
        }
        allow read, write: if isOwner(userId);
      }

      // Synced Contacts (Private)
      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 4. Incident Records
    match /incidents/{incidentId} {
      function isValidIncident(data) {
        return isValidId(data.userId)
          && data.type in ['SOS', 'MEDICAL', 'THREAT']
          && data.status in ['ACTIVATED', 'CANCELLED', 'RESOLVED']
          && data.location.lat is number
          && data.location.lng is number;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidIncident(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
    }

    // 5. Safety Checks
    match /safety_checks/{checkId} {
      function isValidSafetyCheck(data) {
        return data.userId is string 
          && data.status == 'SAFE'
          && data.type == 'MANUAL_CHECK';
      }
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidSafetyCheck(incoming());
    }
  }
}
